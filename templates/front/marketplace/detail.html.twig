{% extends 'front/base_home.html.twig' %}

{% block title %}{{ article.titre }} - EduVie Marketplace{% endblock %}

{% block body %}
<div class="min-h-screen bg-background">
    <!-- Navigation -->
    <nav class="fixed top-0 w-full z-50 border-b border-white/10 bg-background/80 backdrop-blur-xl">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <a href="{{ path('app_marketplace_index') }}" class="flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors">
                <i data-lucide="arrow-left" class="w-5 h-5"></i>
                <span class="text-sm">Retour au catalogue</span>
            </a>
            
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-primary flex items-center justify-center">
                    <i data-lucide="graduation-cap" class="w-6 h-6 text-white"></i>
                </div>
                <button
                    id="cartToggle"
                    type="button"
                    class="relative w-10 h-10 rounded-xl bg-secondary border border-white/10 flex items-center justify-center hover:bg-white/5 transition-colors"
                    title="Voir le panier"
                >
                    <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                    <span id="cartCount" class="hidden absolute -top-1 -right-1 min-w-[1.15rem] h-[1.15rem] px-1 rounded-full bg-primary text-white text-[10px] leading-[1.15rem] font-bold">0</span>
                </button>
            </div>
        </div>
    </nav>

    <!-- Content -->
    <div class="pt-32 pb-24 px-6">
        <div class="max-w-7xl mx-auto">
            <div class="grid lg:grid-cols-2 gap-12">
                <!-- Left - Images -->
                <div class="space-y-4">
                    <div class="glass-card rounded-3xl p-4">
                        <div class="aspect-square rounded-2xl overflow-hidden">
                            <img id="mainImage" src="{{ asset('images/' ~ article.image) }}" alt="{{ article.titre }}" onerror="this.onerror=null;this.style.display='none';" class="w-full h-full object-cover">
                        </div>
                    </div>
                    
                    <!-- Thumbnails -->
                    <div class="flex gap-3">
                        {% for img in article.images %}
                        <button onclick="document.getElementById('mainImage').src = '{{ asset('images/' ~ img) }}'" class="w-20 h-20 rounded-xl overflow-hidden border-2 border-transparent hover:border-primary transition-all">
                            <img src="{{ asset('images/' ~ img) }}" onerror="this.onerror=null;this.style.display='none';" class="w-full h-full object-cover">
                        </button>
                        {% endfor %}
                    </div>
                </div>

                <!-- Right - Details & Purchase -->
                <div class="space-y-6">
                    <!-- Header -->
                    <div>
                        <div class="flex items-center gap-2 mb-3">
                            <span class="px-3 py-1 rounded-full text-xs font-medium {{ article.type == 'academic' ? 'bg-academic/20 text-academic' : 'bg-personal/20 text-personal' }}">
                                {{ article.type == 'academic' ? 'Academic' : 'Personal' }}
                            </span>
                            <span class="px-3 py-1 rounded-full text-xs font-medium bg-secondary text-muted-foreground">
                                {{ article.categorie.nom }}
                            </span>
                            <span class="px-3 py-1 rounded-full text-xs font-medium bg-green-500/20 text-green-400 flex items-center gap-1">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                                {{ article.statut }}
                            </span>
                        </div>
                        
                        <h1 class="font-serif text-3xl md:text-4xl font-medium mb-4">{{ article.titre }}</h1>
                        
                        <div class="flex items-center gap-4 mb-6">
                            <div class="flex items-center gap-2">
                                <img src="{{ asset('images/' ~ article.vendeur.avatar) }}" class="w-10 h-10 rounded-full object-cover ring-2 ring-primary/30">
                                <div>
                                    <p class="font-medium">{{ article.vendeur.nom }}</p>
                                    <p class="text-xs text-muted-foreground">{{ article.vendeur.niveau }}</p>
                                </div>
                            </div>
                            <div class="h-8 w-px bg-white/10"></div>
                            <div class="flex items-center gap-1 text-sm text-muted-foreground">
                                <i data-lucide="star" class="w-4 h-4 text-yellow-500 fill-yellow-500"></i>
                                <span class="font-medium text-foreground">{{ article.vendeur.note }}</span>
                                <span>({{ article.vendeur.annonces }} annonces)</span>
                            </div>
                        </div>
                        
                        <p class="font-serif text-4xl font-bold text-primary mb-2">{{ article.prix }} €</p>
                        <p class="text-sm text-muted-foreground">Prix negociable</p>
                    </div>

                    <!-- Description -->
                    <div class="glass-card rounded-2xl p-6">
                        <h3 class="font-medium mb-3">Description</h3>
                        <p class="text-muted-foreground leading-relaxed whitespace-pre-line">{{ article.contenu }}</p>
                    </div>

                    <!-- Purchase Form -->
                    <div class="glass-card rounded-3xl p-6 border border-primary/30">
                        <h3 class="font-serif text-xl font-medium mb-4 flex items-center gap-2">
                            <i data-lucide="shopping-cart" class="w-5 h-5 text-primary"></i>
                            Formulaire d'achat
                        </h3>
                        
                        <form id="purchaseForm" method="post" class="space-y-4" novalidate>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-medium mb-2 text-muted-foreground">Prenom</label>
                                    <input id="buyerFirstName" name="prenom" type="text" required maxlength="40" class="w-full h-12 bg-secondary border border-white/10 rounded-xl px-4 focus:outline-none focus:border-primary transition-all" placeholder="Jean">
                                </div>
                                <div>
                                    <label class="block text-sm font-medium mb-2 text-muted-foreground">Nom</label>
                                    <input id="buyerLastName" name="nom" type="text" required maxlength="40" class="w-full h-12 bg-secondary border border-white/10 rounded-xl px-4 focus:outline-none focus:border-primary transition-all" placeholder="Dupont">
                                </div>
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium mb-2 text-muted-foreground">Email universitaire</label>
                                <input id="buyerEmail" name="email" type="email" required class="w-full h-12 bg-secondary border border-white/10 rounded-xl px-4 focus:outline-none focus:border-primary transition-all" placeholder="jean.dupont@univ.fr">
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium mb-2 text-muted-foreground">Telephone</label>
                                <input id="buyerPhone" name="telephone" type="tel" required class="w-full h-12 bg-secondary border border-white/10 rounded-xl px-4 focus:outline-none focus:border-primary transition-all" placeholder="06 12 34 56 78">
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium mb-2 text-muted-foreground">Message au vendeur (optionnel)</label>
                                <textarea id="buyerMessage" name="message" rows="3" maxlength="500" class="w-full bg-secondary border border-white/10 rounded-xl p-4 focus:outline-none focus:border-primary transition-all resize-none" placeholder="Bonjour, je suis interesse par votre article..."></textarea>
                            </div>
                            
                            <div class="flex items-center gap-3 p-4 bg-secondary/50 rounded-xl">
                                <input id="buyerConfirm" name="confirm" type="checkbox" required class="w-5 h-5 rounded border-white/10 bg-secondary text-primary focus:ring-primary">
                                <span class="text-sm text-muted-foreground">Je confirme etre etudiant et avoir lu les <a href="#" class="text-primary hover:underline">conditions de vente</a></span>
                            </div>
                            <p id="purchaseFormError" class="hidden text-center text-xs text-red-400"></p>
                            
                            <button
                                id="addToCartBtn"
                                type="button"
                                class="w-full h-14 bg-primary text-white rounded-xl font-medium hover:bg-primary/90 transition-all shadow-lg shadow-primary/25 flex items-center justify-center gap-2"
                                data-article-id="{{ article.id }}"
                                data-article-title="{{ article.titre }}"
                                data-article-price="{{ article.prix }}"
                                data-article-image="{{ asset('images/' ~ article.image) }}"
                                data-article-url="{{ path('app_marketplace_detail', {id: article.id}) }}"
                            >
                                <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                                Ajouter au panier
                            </button>
                            <p id="cartMessage" class="hidden text-center text-xs text-green-400">Article ajoute au panier</p>
                            
                            <p class="text-center text-xs text-muted-foreground">
                                Le paiement se fait en main propre sur le campus
                            </p>
                        </form>
                    </div>

                    <!-- Stats -->
                    <div class="flex items-center justify-between text-sm text-muted-foreground">
                        <span class="flex items-center gap-2">
                            <i data-lucide="eye" class="w-4 h-4"></i>
                            {{ article.vues }} vues
                        </span>
                        <span class="flex items-center gap-2">
                            <i data-lucide="clock" class="w-4 h-4"></i>
                            Publie le {{ article.date|date('d M Y') }}
                        </span>
                    </div>
                </div>
            </div>

            <!-- Similar Articles -->
            <section class="mt-16">
                <h2 class="font-serif text-2xl font-medium mb-6">Articles similaires</h2>
                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    {% for sim in articles_similaires %}
                    <a href="{{ path('app_marketplace_detail', {id: sim.id}) }}" class="glass-card rounded-2xl overflow-hidden hover:border-primary/30 transition-all group">
                        <div class="h-40 overflow-hidden">
                            <img src="{{ asset('images/' ~ sim.image) }}" onerror="this.onerror=null;this.style.display='none';" class="w-full h-full object-cover group-hover:scale-105 transition-transform">
                        </div>
                        <div class="p-4">
                            <h3 class="font-medium mb-2 group-hover:text-primary transition-colors">{{ sim.titre }}</h3>
                            <p class="font-serif text-xl font-bold text-primary">{{ sim.prix }} €</p>
                        </div>
                    </a>
                    {% endfor %}
                </div>
            </section>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            const STORAGE_KEY = 'marketplace_cart';
            const addBtn = document.getElementById('addToCartBtn');
            const purchaseForm = document.getElementById('purchaseForm');
            const cartToggle = document.getElementById('cartToggle');
            const cartCount = document.getElementById('cartCount');
            const cartMessage = document.getElementById('cartMessage');
            const purchaseFormError = document.getElementById('purchaseFormError');
            const buyerFirstName = document.getElementById('buyerFirstName');
            const buyerLastName = document.getElementById('buyerLastName');
            const buyerEmail = document.getElementById('buyerEmail');
            const buyerPhone = document.getElementById('buyerPhone');
            const buyerMessage = document.getElementById('buyerMessage');
            const buyerConfirm = document.getElementById('buyerConfirm');
            const navContainer = cartToggle ? cartToggle.parentElement : null;
            let cartPanel = null;

            function readCart() {
                try {
                    const raw = localStorage.getItem(STORAGE_KEY);
                    const parsed = raw ? JSON.parse(raw) : [];
                    return Array.isArray(parsed) ? parsed : [];
                } catch (e) {
                    return [];
                }
            }

            function writeCart(items) {
                localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
            }

            function updateCount() {
                const total = readCart().length;
                if (!cartCount) return;
                if (total > 0) {
                    cartCount.classList.remove('hidden');
                    cartCount.textContent = String(total);
                } else {
                    cartCount.classList.add('hidden');
                    cartCount.textContent = '0';
                }
            }

            function createPanelIfMissing() {
                if (cartPanel || !navContainer) return;
                cartPanel = document.createElement('div');
                cartPanel.id = 'cartPanel';
                cartPanel.className = 'hidden absolute top-16 right-0 w-80 max-w-[90vw] glass-card rounded-2xl p-4 border border-white/10 z-50';
                cartPanel.innerHTML = '<h4 class="font-medium mb-3">Mon panier</h4><div id="cartPanelItems" class="space-y-2 text-sm text-muted-foreground"></div>';
                navContainer.classList.add('relative');
                navContainer.appendChild(cartPanel);
            }

            function renderPanel() {
                createPanelIfMissing();
                if (!cartPanel) return;
                const itemsContainer = cartPanel.querySelector('#cartPanelItems');
                const items = readCart();

                if (!itemsContainer) return;

                if (items.length === 0) {
                    itemsContainer.innerHTML = '<p>Votre panier est vide.</p>';
                    return;
                }

                itemsContainer.innerHTML = items.map(function (item) {
                    const safeTitle = String(item.title || '');
                    const safePrice = String(item.price || '');
                    const safeUrl = String(item.url || '#');
                    return '<a href="' + safeUrl + '" class="flex items-center justify-between gap-3 p-2 rounded-lg hover:bg-white/5 transition-colors"><span class="truncate">' + safeTitle + '</span><span class="text-primary font-medium whitespace-nowrap">' + safePrice + ' EUR</span></a>';
                }).join('');
            }

            function setFieldValidity(field, valid) {
                if (!field) return;
                field.classList.remove('border-red-500', 'focus:border-red-500');
                if (!valid) {
                    field.classList.add('border-red-500', 'focus:border-red-500');
                }
            }

            function validatePurchaseForm() {
                if (!purchaseForm) return false;

                const firstName = (buyerFirstName ? buyerFirstName.value : '').trim();
                const lastName = (buyerLastName ? buyerLastName.value : '').trim();
                const email = (buyerEmail ? buyerEmail.value : '').trim();
                const rawPhone = (buyerPhone ? buyerPhone.value : '').trim();
                const phone = rawPhone.replace(/[\s.\-]/g, '');
                const message = (buyerMessage ? buyerMessage.value : '').trim();
                const isConfirmed = !!(buyerConfirm && buyerConfirm.checked);

                const nameRegex = /^[A-Za-zÀ-ÖØ-öø-ÿ' -]{2,40}$/;
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                const phoneRegex = /^(?:\+33|0)[1-9]\d{8}$/;

                let formIsValid = true;
                let firstError = '';

                const firstNameValid = nameRegex.test(firstName);
                setFieldValidity(buyerFirstName, firstNameValid);
                if (!firstNameValid && !firstError) {
                    firstError = 'Prenom invalide (2 a 40 lettres).';
                    formIsValid = false;
                }

                const lastNameValid = nameRegex.test(lastName);
                setFieldValidity(buyerLastName, lastNameValid);
                if (!lastNameValid && !firstError) {
                    firstError = 'Nom invalide (2 a 40 lettres).';
                    formIsValid = false;
                }

                const emailValid = emailRegex.test(email);
                setFieldValidity(buyerEmail, emailValid);
                if (!emailValid && !firstError) {
                    firstError = 'Email invalide.';
                    formIsValid = false;
                }

                const phoneValid = phoneRegex.test(phone);
                setFieldValidity(buyerPhone, phoneValid);
                if (!phoneValid && !firstError) {
                    firstError = 'Telephone invalide (ex: 06 12 34 56 78).';
                    formIsValid = false;
                }

                const messageValid = (message === '') || message.length >= 10;
                setFieldValidity(buyerMessage, messageValid);
                if (!messageValid && !firstError) {
                    firstError = 'Le message doit contenir au moins 10 caracteres.';
                    formIsValid = false;
                }

                setFieldValidity(buyerConfirm, isConfirmed);
                if (!isConfirmed && !firstError) {
                    firstError = 'Veuillez confirmer les conditions de vente.';
                    formIsValid = false;
                }

                if (purchaseFormError) {
                    if (formIsValid) {
                        purchaseFormError.textContent = '';
                        purchaseFormError.classList.add('hidden');
                    } else {
                        purchaseFormError.textContent = firstError;
                        purchaseFormError.classList.remove('hidden');
                    }
                }

                return formIsValid;
            }

            [buyerFirstName, buyerLastName, buyerEmail, buyerPhone, buyerMessage, buyerConfirm].forEach(function (field) {
                if (!field) return;
                field.addEventListener('input', function () {
                    if (purchaseFormError) {
                        purchaseFormError.textContent = '';
                        purchaseFormError.classList.add('hidden');
                    }
                    setFieldValidity(field, true);
                });
                field.addEventListener('change', function () {
                    if (purchaseFormError) {
                        purchaseFormError.textContent = '';
                        purchaseFormError.classList.add('hidden');
                    }
                    setFieldValidity(field, true);
                });
            });

            if (addBtn) {
                addBtn.addEventListener('click', function () {
                    if (!validatePurchaseForm()) {
                        return;
                    }

                    const article = {
                        id: addBtn.dataset.articleId,
                        title: addBtn.dataset.articleTitle,
                        price: addBtn.dataset.articlePrice,
                        image: addBtn.dataset.articleImage,
                        url: addBtn.dataset.articleUrl
                    };

                    const cart = readCart();
                    const exists = cart.some(function (item) { return String(item.id) === String(article.id); });
                    if (!exists) {
                        cart.push(article);
                        writeCart(cart);
                    }

                    updateCount();
                    renderPanel();

                    if (cartMessage) {
                        cartMessage.classList.remove('hidden');
                        setTimeout(function () {
                            cartMessage.classList.add('hidden');
                        }, 1800);
                    }
                });
            }

            if (cartToggle) {
                cartToggle.addEventListener('click', function () {
                    createPanelIfMissing();
                    renderPanel();
                    if (!cartPanel) return;
                    cartPanel.classList.toggle('hidden');
                });
            }

            document.addEventListener('click', function (event) {
                if (!cartPanel || !cartToggle) return;
                const clickedInsidePanel = cartPanel.contains(event.target);
                const clickedToggle = cartToggle.contains(event.target);
                if (!clickedInsidePanel && !clickedToggle) {
                    cartPanel.classList.add('hidden');
                }
            });

            updateCount();
        })();
    </script>
{% endblock %}
